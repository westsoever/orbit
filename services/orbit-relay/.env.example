# Copy to .env and fill in before running the relay.
OPENROUTER_API_KEY=
ORBIT_RELAY_SECRET=

# Optional limits (defaults shown)
# DAILY_REQUESTS_PER_DEVICE=40
# DAILY_TOKENS_PER_DEVICE=80000
# DAILY_REQUESTS_PER_IP=200
# MAX_REGISTRATIONS_PER_IP_PER_DAY=3
# MAX_PROMPT_CHARS=32000
# INVITE_CODE=
# RELAY_DISABLED=0
# RELAY_DATABASE_PATH=relay.db
# ORBIT_DEFAULT_MODEL=owl-alpha
# TOKEN_TTL_DAYS=365
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
